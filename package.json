{
  "name": "@laxture/vibe-pm",
  "version": "0.1.8",
  "license": "Apache-2.0",
  "repository": "https://github.com/hank-cp/opencode-vibe-pm",
  "keywords": [
    "opencode",
    "plugin",
    "llm",
    "task",
    "flow",
    "vibe-coding"
  ],
  "author": "@laxture/hank-cp",
  "type": "module",
  "description": "OpenCode plugin that ensure llm processes tasks follow the given flow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui/index.d.ts",
      "import": "./dist/tui/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && bun run scripts/build-tui.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@opentui/core": "^0.3.4",
    "@opentui/keymap": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/bun": "^1.3.14",
    "eslint": "^9.39.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "llama-tokenizer-js": "^1.2.2",
    "llama3-tokenizer-js": "^1.2.0",
    "solid-js": "^1.9.13",
    "tiktoken": "^1.0.22",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.4"
  }
}
