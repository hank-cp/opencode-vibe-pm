{
  "name": "vibe-pm",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --emitDeclarationOnly && bun build ./src/index.ts --outfile ./dist/index.js --target bun --format esm",
    "postinstall": "node scripts/patch-opentui-jsx-runtime.mjs",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.4",
    "@opentui/core": "^0.3.4",
    "@opentui/keymap": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "axiodb": "^9.6.6",
    "solid-js": "^1.9.13",
    "tiktoken": "^1.0.22",
    "zod": "^3.23.0"
  }
}
